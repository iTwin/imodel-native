/* =============================================================================
 * ECSql.y — BISON grammar for ECSQL with Exp-tree construction
 *
 * Generated from ECSqlRDParser.cpp.  Builds the same AST node graph that the
 * hand-written recursive-descent parser produces.
 *
 * NOTE: Some AST constructors (ClassNameExp, view-class expansion, enum-value
 * resolution) require an ECSqlParseContext reference that is not available
 * inside pure BISON actions.  These are marked with RESOLVE comments — a
 * post-parse "FinalizeParsing" pass handles them, exactly as the RD parser
 * already does.
 *
 * Copyright (c) Bentley Systems, Incorporated. All rights reserved.
 * =========================================================================== */

%{
#include "ECDbPch.h"
#include "ECSqlBisonParser.h"     /* BisonParseResult + AST headers            */

USING_NAMESPACE_BENTLEY_SQLITE_EC
USING_NAMESPACE_BENTLEY_EC

#include "ECSql.tab.hpp"          /* generated by bison (re-include is no-op)  */

/* Forward: the lexer function produced by Flex */
extern int yylex(ECSqlYYSTYPE* lvalp, void* scanner);

/* yyerror is called by bison on parse errors */
static void yyerror(BisonParseResult* result, ECSqlParseContext* ctx, void* scanner, const char* msg)
    {
    if (result) result->errorMessage = msg;
    ctx->Issues().ReportV(IssueSeverity::Error, IssueCategory::BusinessProperties, ECN::IssueType::ECSQL,
        ECDbIssueId::ECDb_0475, "ECSQL parse error: %s", msg);
    }

/* Convenience: the parse context is passed via %parse-param */
#define CTX (*ctx)

/* Helper to create a literal ValueExp through LiteralValueExp::Create */
static std::unique_ptr<ValueExp> MakeLiteral(ECSqlParseContext& ctx, Utf8CP val, ECSqlTypeInfo const& ti)
    {
    std::unique_ptr<ValueExp> exp;
    LiteralValueExp::Create(exp, ctx, val, ti);
    return exp;
    }

%}

/* ── %code requires: injected into ECSql.tab.hpp (keep in sync with manual edit) ── */
%code requires {
#include "ECSqlBisonParser.h"
USING_NAMESPACE_BENTLEY_SQLITE_EC
}

/* ── BISON configuration ────────────────────────────────────────────────── */

%define api.pure full
%parse-param { BisonParseResult* result }
%parse-param { ECSqlParseContext* ctx }
%parse-param { void* scanner }
%lex-param   { void* scanner }

%define parse.error verbose

/* ── Semantic value union ────────────────────────────────────────────────── */

%union {
    char*  strVal;       /* heap-allocated string — caller frees */
    int    intVal;
    bool   boolVal;

    /* owning raw pointers; BISON does not support unique_ptr in unions.
       Each $$ assignment is immediately wrapped into unique_ptr by the
       receiving rule.  Leaks on parse error are acceptable for this
       reference grammar (production code would use %destructor). */

    Exp*                                exp;
    ValueExp*                           valueExp;
    ComputedExp*                        computedExp;
    BooleanExp*                         booleanExp;
    ClassRefExp*                        classRefExp;
    ClassNameExp*                       classNameExp;
    JoinExp*                            joinExp;
    JoinSpecExp*                        joinSpecExp;
    SubqueryExp*                        subqueryExp;
    SelectStatementExp*                 selectStmtExp;
    SingleSelectStatementExp*           singleSelectExp;
    SelectClauseExp*                    selectClauseExp;
    DerivedPropertyExp*                 derivedPropExp;
    FromExp*                            fromExp;
    WhereExp*                           whereExp;
    GroupByExp*                         groupByExp;
    HavingExp*                          havingExp;
    OrderByExp*                         orderByExp;
    OrderBySpecExp*                     orderBySpecExp;
    LimitOffsetExp*                     limitOffsetExp;
    OptionsExp*                         optionsExp;
    OptionExp*                          optionExp;
    PropertyNameExp*                    propNameExp;
    PropertyNameListExp*                propNameListExp;
    AssignmentListExp*                  assignListExp;
    AssignmentExp*                      assignExp;
    ValueExpListExp*                    valueExpListExp;
    InsertStatementExp*                 insertStmtExp;
    UpdateStatementExp*                 updateStmtExp;
    DeleteStatementExp*                 deleteStmtExp;
    PragmaStatementExp*                 pragmaStmtExp;
    CommonTableExp*                     cteExp;
    CommonTableBlockExp*                cteBlockExp;
    WindowFunctionClauseExp*            windowClauseExp;
    WindowSpecification*                windowSpecExp;
    WindowFunctionExp*                  windowFuncExp;
    WindowFrameClauseExp*               frameClauseExp;
    WindowFrameStartExp*                frameStartExp;
    WindowFrameBetweenExp*              frameBetweenExp;
    FirstWindowFrameBoundExp*           firstBoundExp;
    SecondWindowFrameBoundExp*          secondBoundExp;
    FilterClauseExp*                    filterClauseExp;
    WindowPartitionColumnReferenceListExp* partitionListExp;
    WindowDefinitionExp*                windowDefExp;

    /* enum carriers */
    SqlSetQuantifier                    setQuantifier;
    BinarySqlOperator                   binOp;
    BooleanSqlOperator                  boolOp;
    UnaryValueExp::Operator             unaryOp;
    ECSqlJoinType                       joinType;
    JoinDirection                       joinDir;
    SelectStatementExp::CompoundOperator compoundOp;
    PolymorphicInfo*                    polyInfo;   /* heap-allocated */
    OrderBySpecExp::SortDirection       sortDir;
    OrderBySpecExp::NullsOrder          nullsOrder;
    WindowFrameClauseExp::WindowFrameUnit frameUnit;
    WindowFrameClauseExp::WindowFrameExclusionType frameExcl;
    WindowPartitionColumnReferenceExp::CollateClauseFunction collateFunc;
    SqlCompareListType                  compareListType;

    /* list carriers (raw vectors, transferred into AST nodes) */
    std::vector<std::unique_ptr<CommonTableBlockExp>>*  cteBlockList;
    std::vector<std::unique_ptr<OrderBySpecExp>>*       orderBySpecList;
    std::vector<std::unique_ptr<ValueExp>>*             valueExpVec;
    std::vector<Utf8String>*                            stringVec;
    std::vector<std::unique_ptr<ClassNameExp>>*          classNameVec;
    std::vector<std::unique_ptr<WindowPartitionColumnReferenceExp>>* partColRefVec;
    std::vector<std::unique_ptr<WindowDefinitionExp>>*   windowDefVec;
    std::vector<std::unique_ptr<SearchedWhenClauseExp>>* whenClauseVec;
    PragmaVal*                          pragmaValPtr;
}

/* ── Token declarations ──────────────────────────────────────────────────── */

%token <strVal> NAME            "identifier"
%token <strVal> INTEGER_LITERAL "integer literal"
%token <strVal> APPROX_LITERAL  "float literal"
%token <strVal> STRING_LITERAL  "string literal"
%token <strVal> NAMED_PARAM     "named parameter"
%token          PARAMETER       "?"
%token          DOLLAR          "$"

%token LESS GREAT EQUAL LESS_EQ GREAT_EQ NOT_EQUAL
%token CONCAT ARROW BITWISE_NOT BITWISE_OR BITWISE_AND SHIFT_LEFT SHIFT_RIGHT

%token MINUS PLUS STAR SLASH PERCENT COLON
%token LPAREN RPAREN COMMA DOT SEMICOLON
%token LBRACE RBRACE LBRACKET RBRACKET

/* Keywords */
%token KW_ALL KW_AND KW_ANY KW_AS KW_ASC KW_AVG
%token KW_BACKWARD KW_BETWEEN KW_BINARY KW_BLOB KW_BOOLEAN KW_BY
%token KW_CASE KW_CAST KW_COLLATE KW_COUNT KW_CROSS
%token KW_CUME_DIST KW_CURRENT KW_CURRENT_DATE KW_CURRENT_TIME KW_CURRENT_TIMESTAMP
%token KW_DATE KW_DELETE KW_DENSE_RANK KW_DESC KW_DISTINCT KW_DOUBLE
%token KW_ECSQLOPTIONS KW_ELSE KW_END KW_ESCAPE KW_EVERY KW_EXCEPT
%token KW_EXCLUDE KW_EXISTS KW_FALSE KW_FILTER KW_FIRST KW_FIRST_VALUE
%token KW_FLOAT KW_FOLLOWING KW_FOR KW_FORWARD KW_FROM KW_FULL
%token KW_GROUP KW_GROUP_CONCAT KW_GROUPS KW_HAVING
%token KW_IIF KW_IN KW_INNER KW_INSERT KW_INT KW_INT64 KW_INTERSECT KW_INTO
%token KW_IS KW_JOIN
%token KW_LAG KW_LAST KW_LAST_VALUE KW_LEAD KW_LEFT KW_LIKE KW_LIMIT KW_LONG
%token KW_MATCH KW_MAX KW_MIN KW_NATURAL KW_NAVIGATION_VALUE
%token KW_NO KW_NOCASE KW_NOT KW_NTH_VALUE KW_NTILE KW_NULL KW_NULLS
%token KW_OFFSET KW_ON KW_ONLY KW_OPTIONS KW_OR KW_ORDER KW_OTHERS KW_OUTER KW_OVER
%token KW_PARTITION KW_PERCENT_RANK KW_PRAGMA KW_PRECEDING
%token KW_RANGE KW_RANK KW_REAL KW_RECURSIVE KW_RIGHT
%token KW_ROW KW_ROWS KW_ROW_NUMBER KW_RTRIM
%token KW_SELECT KW_SET KW_SOME KW_STRING_KW KW_SUM
%token KW_THEN KW_TIES KW_TIME KW_TIMESTAMP KW_TOTAL KW_TRUE
%token KW_UNBOUNDED KW_UNION KW_UNIQUE KW_UNKNOWN KW_UPDATE KW_USING
%token KW_VALUE KW_VALUES KW_VARCHAR KW_WHEN KW_WHERE KW_WINDOW KW_WITH

/* ── Non-terminal types ──────────────────────────────────────────────────── */

%type <exp>                 ecsql_statement
%type <selectStmtExp>       select_statement values_statement
%type <singleSelectExp>     single_select_statement
%type <selectClauseExp>     selection
%type <derivedPropExp>      derived_column
%type <strVal>              opt_column_alias identifier
%type <setQuantifier>       opt_set_quantifier
%type <fromExp>             opt_from_clause from_clause
%type <whereExp>            opt_where_clause where_clause
%type <groupByExp>          opt_group_by_clause
%type <havingExp>           opt_having_clause
%type <orderByExp>          opt_order_by_clause order_by_clause
%type <orderBySpecList>     order_by_spec_list
%type <orderBySpecExp>      order_by_spec
%type <sortDir>             opt_sort_direction
%type <nullsOrder>          opt_nulls_order
%type <limitOffsetExp>      opt_limit_offset_clause
%type <optionsExp>          opt_ecsqloptions_clause
%type <optionExp>           option_item
%type <windowClauseExp>     opt_window_clause
%type <compoundOp>          compound_op
%type <boolVal>             opt_all

%type <insertStmtExp>       insert_statement
%type <updateStmtExp>       update_statement
%type <deleteStmtExp>       delete_statement
%type <pragmaStmtExp>       pragma_statement
%type <cteExp>              cte_statement

%type <classNameExp>        table_node
%type <classRefExp>         table_ref table_ref_body table_ref_and_joins
%type <polyInfo>            opt_polymorphic_constraint opt_all_or_only
%type <boolVal>             opt_disqualify_prefix
%type <strVal>              opt_table_alias

%type <joinType>            join_type
%type <joinDir>             opt_join_direction
%type <joinSpecExp>         join_spec
%type <subqueryExp>         subquery

%type <propNameListExp>     opt_column_ref_commalist
%type <assignListExp>       assignment_commalist
%type <propNameExp>         property_name_exp
%type <valueExpVec>         row_value_constructor_commalist

%type <valueExp>            value_exp value_exp_or value_exp_and
%type <valueExp>            value_exp_shift value_exp_addsub
%type <valueExp>            value_exp_muldiv value_exp_concat
%type <valueExp>            value_exp_unary value_exp_primary
%type <valueExp>            literal cast_spec case_exp iif_exp
%type <valueExp>            column_ref_or_func function_call
%type <valueExpListExp>     value_exp_commalist

%type <booleanExp>          search_condition search_condition_or
%type <booleanExp>          search_condition_and search_condition_not
%type <booleanExp>          predicate

%type <boolOp>              comparison_op
%type <compareListType>     quantifier

%type <cteBlockList>        cte_block_list
%type <cteBlockExp>         cte_block
%type <stringVec>           column_name_commalist opt_column_name_list

%type <classNameVec>        type_list
%type <classNameExp>        type_list_entry

%type <windowSpecExp>       window_specification
%type <windowDefVec>        window_definition_list
%type <windowDefExp>        window_definition
%type <partitionListExp>    opt_partition_clause
%type <partColRefVec>       partition_column_list
%type <collateFunc>         opt_collate_clause
%type <frameClauseExp>      opt_frame_clause
%type <frameUnit>           frame_unit
%type <frameStartExp>       frame_start
%type <frameBetweenExp>     frame_between
%type <firstBoundExp>       first_frame_bound
%type <secondBoundExp>      second_frame_bound
%type <frameExcl>           opt_frame_exclusion
%type <filterClauseExp>     opt_filter_clause

%type <pragmaValPtr>        pragma_value opt_pragma_value
%type <stringVec>           opt_pragma_for_path
%type <stringVec>           pragma_path
%type <selectClauseExp>     select_item_list
%type <valueExp>            opt_escape

%type <boolVal>             opt_not

/* ── Precedence (only for disambiguation, not expression building) ────── */

%left KW_OR
%left KW_AND
%right KW_NOT

%%

/* ==========================================================================
 * Top-level
 * ========================================================================== */

ecsql_statement
    : cte_statement opt_semicolon
        { $$ = $1; result->exp.reset($$); }
    | select_statement opt_semicolon
        { $$ = $1; result->exp.reset($$); }
    | insert_statement opt_semicolon
        { $$ = $1; result->exp.reset($$); }
    | update_statement opt_semicolon
        { $$ = $1; result->exp.reset($$); }
    | delete_statement opt_semicolon
        { $$ = $1; result->exp.reset($$); }
    | pragma_statement opt_semicolon
        { $$ = $1; result->exp.reset($$); }
    ;

opt_semicolon : /* empty */ | SEMICOLON ;

/* ==========================================================================
 * INSERT
 * ========================================================================== */

insert_statement
    : KW_INSERT KW_INTO opt_all_or_only table_node
        opt_column_ref_commalist KW_VALUES LPAREN row_value_constructor_commalist RPAREN
        {
            auto classExp  = std::unique_ptr<ClassNameExp>($4);
            auto propList  = std::unique_ptr<PropertyNameListExp>($5);
            auto& vals     = *$8;
            $$ = new InsertStatementExp(classExp, propList, vals);
            delete $8;
            delete $3; /* PolymorphicInfo */
        }
    ;

/* ==========================================================================
 * UPDATE
 * ========================================================================== */

update_statement
    : KW_UPDATE opt_all_or_only table_node KW_SET assignment_commalist
        opt_where_clause opt_ecsqloptions_clause
        {
            $$ = new UpdateStatementExp(
                std::unique_ptr<ClassNameExp>($3),
                std::unique_ptr<AssignmentListExp>($5),
                std::unique_ptr<WhereExp>($6),
                std::unique_ptr<OptionsExp>($7));
            delete $2;
        }
    ;

/* ==========================================================================
 * DELETE
 * ========================================================================== */

delete_statement
    : KW_DELETE KW_FROM opt_all_or_only table_node
        opt_where_clause opt_ecsqloptions_clause
        {
            $$ = new DeleteStatementExp(
                std::unique_ptr<ClassNameExp>($4),
                std::unique_ptr<WhereExp>($5),
                std::unique_ptr<OptionsExp>($6));
            delete $3;
        }
    ;

/* ==========================================================================
 * PRAGMA
 * ========================================================================== */

pragma_statement
    : KW_PRAGMA identifier opt_pragma_value opt_pragma_for_path opt_ecsqloptions_clause
        {
            PragmaVal pv = $3 ? *$3 : PragmaVal();
            /* isRead=true unless value was supplied via = (write op flag set in opt_pragma_value) */
            bool isRead = ($3 == nullptr || !$3->IsWriteOp());
            auto pathVec = $4 ? *$4 : std::vector<Utf8String>();
            $$ = new PragmaStatementExp(
                Utf8String($2), pv, isRead, pathVec,
                std::unique_ptr<OptionsExp>($5));
            free($2);
            delete $3;
            delete $4;
        }
    ;

opt_pragma_value
    : /* empty */                   { $$ = nullptr; }
    | EQUAL pragma_value            { $2->SetWriteOp(true); $$ = $2; }
    | LPAREN pragma_value RPAREN    { $$ = $2; }
    ;

pragma_value
    : KW_TRUE           { $$ = new PragmaVal(true); }
    | KW_FALSE          { $$ = new PragmaVal(false); }
    | KW_NULL           { $$ = new PragmaVal(); *$$ = nullptr; }
    | INTEGER_LITERAL   { $$ = new PragmaVal((int64_t)std::stoll($1)); free($1); }
    | APPROX_LITERAL    { $$ = new PragmaVal(std::stod($1)); free($1); }
    | STRING_LITERAL    { $$ = new PragmaVal(std::string($1), false); free($1); }
    | identifier        { $$ = new PragmaVal(std::string($1), true); free($1); }
    ;

opt_pragma_for_path
    : /* empty */                   { $$ = nullptr; }
    | KW_FOR pragma_path            { $$ = $2; }
    ;

pragma_path
    : NAME
        { $$ = new std::vector<Utf8String>(); $$->push_back(Utf8String($1)); free($1); }
    | pragma_path DOT NAME
        { $$ = $1; $$->push_back(Utf8String($3)); free($3); }
    | pragma_path COLON NAME
        { $$ = $1; $$->push_back(Utf8String($3)); free($3); }
    | pragma_path NAMED_PARAM
        {
        /* ":name" looks like NAMED_PARAM to the flex lexer, but in pragma paths the
         * colon-separated component must be a NAME token to preserve keyword-rejection.
         * Abort here; the RD parser will handle this statement instead. */
        free($2);
        delete $1;
        YYABORT;
        }
    ;

/* ==========================================================================
 * CTE
 * ========================================================================== */

cte_statement
    : KW_WITH KW_RECURSIVE cte_block_list select_statement
        { $$ = new CommonTableExp(std::unique_ptr<SelectStatementExp>($4), std::move(*$3), true); delete $3; }
    | KW_WITH cte_block_list select_statement
        { $$ = new CommonTableExp(std::unique_ptr<SelectStatementExp>($3), std::move(*$2), false); delete $2; }
    ;

cte_block_list
    : cte_block
        { $$ = new std::vector<std::unique_ptr<CommonTableBlockExp>>();
          $$->push_back(std::unique_ptr<CommonTableBlockExp>($1)); }
    | cte_block_list COMMA cte_block
        { $$ = $1; $$->push_back(std::unique_ptr<CommonTableBlockExp>($3)); }
    ;

cte_block
    : identifier opt_column_name_list KW_AS LPAREN select_statement RPAREN
        {
            if ($2 && !$2->empty())
                $$ = new CommonTableBlockExp($1, *$2, std::unique_ptr<SelectStatementExp>($5));
            else
                $$ = new CommonTableBlockExp($1, std::unique_ptr<SelectStatementExp>($5));
            free($1);
            delete $2;
        }
    ;

opt_column_name_list
    : /* empty */                                   { $$ = nullptr; }
    | LPAREN column_name_commalist RPAREN           { $$ = $2; }
    ;

column_name_commalist
    : identifier
        { $$ = new std::vector<Utf8String>(); $$->push_back(Utf8String($1)); free($1); }
    | column_name_commalist COMMA identifier
        { $$ = $1; $$->push_back(Utf8String($3)); free($3); }
    ;

/* ==========================================================================
 * SELECT (compound)
 * ========================================================================== */

select_statement
    : values_statement                              { $$ = $1; }
    | single_select_statement
        { $$ = new SelectStatementExp(std::unique_ptr<SingleSelectStatementExp>($1)); }
    | single_select_statement compound_op opt_all select_statement
        { $$ = new SelectStatementExp(
            std::unique_ptr<SingleSelectStatementExp>($1),
            $2, $3, std::unique_ptr<SelectStatementExp>($4)); }
    ;

values_statement
    : KW_VALUES LPAREN row_value_constructor_commalist RPAREN
        {
            auto single = std::unique_ptr<SingleSelectStatementExp>(
                new SingleSelectStatementExp(*$3));
            $$ = new SelectStatementExp(std::move(single));
            delete $3;
        }
    | KW_VALUES LPAREN row_value_constructor_commalist RPAREN compound_op opt_all select_statement
        {
            auto single = std::unique_ptr<SingleSelectStatementExp>(
                new SingleSelectStatementExp(*$3));
            $$ = new SelectStatementExp(std::move(single), $5, $6,
                std::unique_ptr<SelectStatementExp>($7));
            delete $3;
        }
    ;

compound_op
    : KW_UNION          { $$ = SelectStatementExp::CompoundOperator::Union; }
    | KW_INTERSECT      { $$ = SelectStatementExp::CompoundOperator::Intersect; }
    | KW_EXCEPT         { $$ = SelectStatementExp::CompoundOperator::Except; }
    ;

opt_all
    : /* empty */       { $$ = false; }
    | KW_ALL            { $$ = true; }
    ;

/* ==========================================================================
 * Single SELECT
 * ========================================================================== */

single_select_statement
    : KW_SELECT opt_set_quantifier selection
        opt_from_clause opt_where_clause opt_group_by_clause
        opt_having_clause opt_window_clause opt_order_by_clause
        opt_limit_offset_clause opt_ecsqloptions_clause
        {
            $$ = new SingleSelectStatementExp($2,
                std::unique_ptr<SelectClauseExp>($3),
                std::unique_ptr<FromExp>($4),
                std::unique_ptr<WhereExp>($5),
                std::unique_ptr<OrderByExp>($9),
                std::unique_ptr<WindowFunctionClauseExp>($8),
                std::unique_ptr<GroupByExp>($6),
                std::unique_ptr<HavingExp>($7),
                std::unique_ptr<LimitOffsetExp>($10),
                std::unique_ptr<OptionsExp>($11));
        }
    ;

opt_set_quantifier
    : /* empty */       { $$ = SqlSetQuantifier::NotSpecified; }
    | KW_ALL            { $$ = SqlSetQuantifier::All; }
    | KW_DISTINCT       { $$ = SqlSetQuantifier::Distinct; }
    ;

/* ==========================================================================
 * Selection
 * ========================================================================== */

selection
    : STAR
        {
            $$ = new SelectClauseExp();
            PropertyPath pp; pp.Push(Exp::ASTERISK_TOKEN);
            $$->AddProperty(std::make_unique<DerivedPropertyExp>(
                std::make_unique<PropertyNameExp>(pp), nullptr));
        }
    | STAR COMMA select_item_list   {
            $$ = $3;
            PropertyPath pp; pp.Push(Exp::ASTERISK_TOKEN);
            $$->PrependProperty(std::make_unique<DerivedPropertyExp>(
                std::make_unique<PropertyNameExp>(pp), nullptr));
        }
    | select_item_list              { $$ = $1; }
    ;

select_item_list
    : derived_column
        { $$ = new SelectClauseExp(); $$->AddProperty(std::unique_ptr<DerivedPropertyExp>($1)); }
    | select_item_list COMMA derived_column
        { $$ = $1; $$->AddProperty(std::unique_ptr<DerivedPropertyExp>($3)); }
    | select_item_list COMMA STAR
        { $$ = $1;
          PropertyPath pp; pp.Push(Exp::ASTERISK_TOKEN);
          $$->AddProperty(std::make_unique<DerivedPropertyExp>(
            std::make_unique<PropertyNameExp>(pp), nullptr)); }
    ;

derived_column
    : value_exp opt_column_alias
        {
            $$ = new DerivedPropertyExp(std::unique_ptr<ValueExp>($1),
                $2 ? $2 : nullptr);
            free($2);
        }
    ;

opt_column_alias
    : /* empty */               { $$ = nullptr; }
    | KW_AS identifier          { $$ = $2; }
    | NAME                      { $$ = $1; }
    ;

/* ==========================================================================
 * FROM clause
 * ========================================================================== */

opt_from_clause
    : /* empty */               { $$ = nullptr; }
    | from_clause               { $$ = $1; }
    ;

from_clause
    : KW_FROM table_ref_and_joins
        {
            $$ = new FromExp();
            $$->TryAddClassRef(CTX, std::unique_ptr<ClassRefExp>($2));
        }
    | from_clause COMMA table_ref_and_joins
        {
            $$ = $1;
            $$->TryAddClassRef(CTX, std::unique_ptr<ClassRefExp>($3));
        }
    ;

table_ref_and_joins
    : table_ref                 { $$ = $1; }
    | table_ref_and_joins join_clause
        {
            /* Set the LHS (from) on the JoinExp that was created with nullptr LHS */
            JoinExp* joinExp = $<joinExp>2;
            joinExp->InsertLHSClassRef(std::unique_ptr<ClassRefExp>($1));
            $$ = joinExp;
        }
    ;

/* ==========================================================================
 * Table reference
 * ========================================================================== */

table_ref
    : opt_polymorphic_constraint opt_disqualify_prefix table_ref_body opt_table_alias
        {
            $$ = $3;
            if ($4) {
                if (auto* rce = dynamic_cast<RangeClassRefExp*>($$))
                    rce->SetAlias(Utf8String($4));
                free($4);
            }
            delete $1; /* PolymorphicInfo */
        }
    ;

opt_disqualify_prefix
    : /* empty */       { $$ = false; }
    | PLUS              { $$ = true; }
    ;

table_ref_body
    : subquery
        { $$ = new SubqueryRefExp(std::unique_ptr<SubqueryExp>($1), nullptr, PolymorphicInfo::NotSpecified()); }
    | NAME DOT NAME
        {
            /* schema.Class — RESOLVE: needs TryResolveClass in finalize */
            $$ = new ClassNameExp(Utf8String($3), Utf8String($1), nullptr,
                nullptr, PolymorphicInfo::NotSpecified());
            free($1); free($3);
        }
    | NAME NAMED_PARAM
        {
            /* schema:Class */
            $$ = new ClassNameExp(Utf8String($2), Utf8String($1), nullptr,
                nullptr, PolymorphicInfo::NotSpecified());
            free($1); free($2);
        }
    | NAME DOT NAME DOT NAME
        {
            /* tableSpace.schema.Class */
            $$ = new ClassNameExp(Utf8String($5), Utf8String($3), $1,
                nullptr, PolymorphicInfo::NotSpecified());
            free($1); free($3); free($5);
        }
    | NAME
        {
            /* CTE block name reference */
            $$ = new CommonTableBlockNameExp($1);
            free($1);
        }
    ;

opt_table_alias
    : /* empty */               { $$ = nullptr; }
    | KW_AS identifier          { $$ = $2; }
    | NAME                      { $$ = $1; }
    ;

/* ==========================================================================
 * Polymorphic constraint
 * ========================================================================== */

opt_polymorphic_constraint
    : /* empty */           { $$ = new PolymorphicInfo(PolymorphicInfo::NotSpecified()); }
    | PLUS KW_ALL           { $$ = new PolymorphicInfo(PolymorphicInfo::Type::All, true); }
    | PLUS KW_ONLY          { $$ = new PolymorphicInfo(PolymorphicInfo::Type::Only, true); }
    | KW_ALL                { $$ = new PolymorphicInfo(PolymorphicInfo::Type::All, false); }
    | KW_ONLY               { $$ = new PolymorphicInfo(PolymorphicInfo::Type::Only, false); }
    ;

opt_all_or_only
    : /* empty */           { $$ = new PolymorphicInfo(PolymorphicInfo::NotSpecified()); }
    | KW_ALL                { $$ = new PolymorphicInfo(PolymorphicInfo::Type::All, false); }
    | KW_ONLY               { $$ = new PolymorphicInfo(PolymorphicInfo::Type::Only, false); }
    ;

/* ==========================================================================
 * Table node (class name) — for INSERT/UPDATE/DELETE
 * ========================================================================== */

table_node
    : NAME DOT NAME
        { /* RESOLVE: needs TryResolveClass in finalize */
          $$ = new ClassNameExp(Utf8String($3), Utf8String($1), nullptr,
            nullptr, PolymorphicInfo::Only());
          free($1); free($3); }
    | NAME NAMED_PARAM
        { $$ = new ClassNameExp(Utf8String($2), Utf8String($1), nullptr,
            nullptr, PolymorphicInfo::Only());
          free($1); free($2); }
    | NAME DOT NAME DOT NAME
        { $$ = new ClassNameExp(Utf8String($5), Utf8String($3), $1,
            nullptr, PolymorphicInfo::Only());
          free($1); free($3); free($5); }
    ;

/* ==========================================================================
 * JOIN
 * ========================================================================== */

join_clause
    : KW_CROSS KW_JOIN table_ref
        { (void)$<classRefExp>-1; /* LHS from table_ref_and_joins */
          /* NOTE: in real integration $-1 would reference the LHS.
             Here we show the construction pattern. */
          $<joinExp>$ = new CrossJoinExp(
            std::unique_ptr<ClassRefExp>(/* LHS */ nullptr),
            std::unique_ptr<ClassRefExp>($3)); }
    | KW_JOIN table_ref join_spec
        { $<joinExp>$ = new QualifiedJoinExp(
            std::unique_ptr<ClassRefExp>(nullptr),
            std::unique_ptr<ClassRefExp>($2),
            ECSqlJoinType::InnerJoin,
            std::unique_ptr<JoinSpecExp>($3)); }
    | join_type KW_JOIN table_ref join_spec
        { $<joinExp>$ = new QualifiedJoinExp(
            std::unique_ptr<ClassRefExp>(nullptr),
            std::unique_ptr<ClassRefExp>($3),
            $1, std::unique_ptr<JoinSpecExp>($4)); }
    | join_type KW_OUTER KW_JOIN table_ref join_spec
        { $<joinExp>$ = new QualifiedJoinExp(
            std::unique_ptr<ClassRefExp>(nullptr),
            std::unique_ptr<ClassRefExp>($4),
            $1, std::unique_ptr<JoinSpecExp>($5)); }
    | KW_NATURAL join_type KW_JOIN table_ref
        { $<joinExp>$ = new NaturalJoinExp(
            std::unique_ptr<ClassRefExp>(nullptr),
            std::unique_ptr<ClassRefExp>($4), $2); }
    | KW_NATURAL KW_JOIN table_ref
        { $<joinExp>$ = new NaturalJoinExp(
            std::unique_ptr<ClassRefExp>(nullptr),
            std::unique_ptr<ClassRefExp>($3), ECSqlJoinType::InnerJoin); }
    | KW_USING table_ref opt_join_direction
        { $<joinExp>$ = new UsingRelationshipJoinExp(
            std::unique_ptr<ClassRefExp>(nullptr),
            std::unique_ptr<ClassRefExp>(nullptr),
            std::unique_ptr<ClassRefExp>($2), $3); }
    ;

join_type
    : KW_INNER          { $$ = ECSqlJoinType::InnerJoin; }
    | KW_LEFT           { $$ = ECSqlJoinType::LeftOuterJoin; }
    | KW_RIGHT          { $$ = ECSqlJoinType::RightOuterJoin; }
    | KW_FULL           { $$ = ECSqlJoinType::FullOuterJoin; }
    ;

opt_join_direction
    : /* empty */       { $$ = JoinDirection::Implied; }
    | KW_FORWARD        { $$ = JoinDirection::Forward; }
    | KW_BACKWARD       { $$ = JoinDirection::Backward; }
    ;

join_spec
    : KW_ON search_condition
        { $$ = new JoinConditionExp(std::unique_ptr<BooleanExp>($2)); }
    | KW_USING LPAREN column_name_commalist RPAREN
        {
            auto nj = new NamedPropertiesJoinExp();
            for (auto& s : *$3) nj->Append(s);
            $$ = nj;
            delete $3;
        }
    ;

/* ==========================================================================
 * Subquery
 * ========================================================================== */

subquery
    : LPAREN select_statement RPAREN
        { $$ = new SubqueryExp(std::unique_ptr<SelectStatementExp>($2)); }
    | LPAREN cte_statement RPAREN
        { $$ = new SubqueryExp(std::unique_ptr<CommonTableExp>($2)); }
    ;

/* ==========================================================================
 * WHERE / GROUP BY / HAVING
 * ========================================================================== */

opt_where_clause
    : /* empty */                   { $$ = nullptr; }
    | where_clause                  { $$ = $1; }
    ;

where_clause
    : KW_WHERE search_condition
        { $$ = new WhereExp(std::unique_ptr<BooleanExp>($2)); }
    ;

opt_group_by_clause
    : /* empty */                   { $$ = nullptr; }
    | KW_GROUP KW_BY value_exp_commalist
        { $$ = new GroupByExp(std::unique_ptr<ValueExpListExp>($3)); }
    ;

opt_having_clause
    : /* empty */                   { $$ = nullptr; }
    | KW_HAVING search_condition
        { $$ = new HavingExp(std::unique_ptr<BooleanExp>($2)); }
    ;

/* ==========================================================================
 * ORDER BY
 * ========================================================================== */

opt_order_by_clause
    : /* empty */                   { $$ = nullptr; }
    | order_by_clause               { $$ = $1; }
    ;

order_by_clause
    : KW_ORDER KW_BY order_by_spec_list
        { $$ = new OrderByExp(*$3); delete $3; }
    ;

order_by_spec_list
    : order_by_spec
        { $$ = new std::vector<std::unique_ptr<OrderBySpecExp>>();
          $$->push_back(std::unique_ptr<OrderBySpecExp>($1)); }
    | order_by_spec_list COMMA order_by_spec
        { $$ = $1; $$->push_back(std::unique_ptr<OrderBySpecExp>($3)); }
    ;

order_by_spec
    : value_exp opt_sort_direction opt_nulls_order
        {
            std::unique_ptr<ComputedExp> sortExp(std::move(std::unique_ptr<ValueExp>($1)));
            $$ = new OrderBySpecExp(sortExp, $2, $3);
        }
    ;

opt_sort_direction
    : /* empty */       { $$ = OrderBySpecExp::SortDirection::NotSpecified; }
    | KW_ASC            { $$ = OrderBySpecExp::SortDirection::Ascending; }
    | KW_DESC           { $$ = OrderBySpecExp::SortDirection::Descending; }
    ;

opt_nulls_order
    : /* empty */       { $$ = OrderBySpecExp::NullsOrder::NotSpecified; }
    | KW_NULLS KW_FIRST { $$ = OrderBySpecExp::NullsOrder::First; }
    | KW_NULLS KW_LAST  { $$ = OrderBySpecExp::NullsOrder::Last; }
    ;

/* ==========================================================================
 * LIMIT / OFFSET
 * ========================================================================== */

opt_limit_offset_clause
    : /* empty */                           { $$ = nullptr; }
    | KW_LIMIT value_exp
        { $$ = new LimitOffsetExp(std::unique_ptr<ValueExp>($2)); }
    | KW_LIMIT value_exp KW_OFFSET value_exp
        { $$ = new LimitOffsetExp(std::unique_ptr<ValueExp>($2),
            std::unique_ptr<ValueExp>($4)); }
    ;

/* ==========================================================================
 * ECSQLOPTIONS
 * ========================================================================== */

opt_ecsqloptions_clause
    : /* empty */                       { $$ = nullptr; }
    | KW_ECSQLOPTIONS option_list       { $$ = $<optionsExp>2; }
    ;

option_list
    : option_item
        { auto oe = new OptionsExp(); oe->AddOptionExp(std::unique_ptr<OptionExp>($1), CTX.Issues());
          $<optionsExp>$ = oe; }
    | option_list option_item
        { $<optionsExp>$ = $<optionsExp>1;
          $<optionsExp>$->AddOptionExp(std::unique_ptr<OptionExp>($2), CTX.Issues()); }
    ;

option_item
    : NAME
        { $$ = new OptionExp($1, "", ECSqlTypeInfo()); free($1); }
    | NAME EQUAL literal
        { Utf8String val = $3->ToECSql();
          $$ = new OptionExp($1, val.c_str(), $3->GetTypeInfo());
          free($1); delete $3; }
    | NAME EQUAL KW_TRUE
        { $$ = new OptionExp($1, "TRUE",
            ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_Boolean)); free($1); }
    | NAME EQUAL KW_FALSE
        { $$ = new OptionExp($1, "FALSE",
            ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_Boolean)); free($1); }
    | NAME EQUAL identifier
        { $$ = new OptionExp($1, $3,
            ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_String)); free($1); free($3); }
    ;

/* ==========================================================================
 * WINDOW clause
 * ========================================================================== */

opt_window_clause
    : /* empty */                       { $$ = nullptr; }
    | KW_WINDOW window_definition_list
        {
            auto defList = std::make_unique<WindowDefinitionListExp>(*$2);
            $$ = new WindowFunctionClauseExp(std::move(defList));
            delete $2;
        }
    ;

window_definition_list
    : window_definition
        { $$ = new std::vector<std::unique_ptr<WindowDefinitionExp>>();
          $$->push_back(std::unique_ptr<WindowDefinitionExp>($1)); }
    | window_definition_list COMMA window_definition
        { $$ = $1; $$->push_back(std::unique_ptr<WindowDefinitionExp>($3)); }
    ;

window_definition
    : identifier KW_AS LPAREN window_specification RPAREN
        { $$ = new WindowDefinitionExp(Utf8String($1), std::unique_ptr<WindowSpecification>($4));
          free($1); }
    ;

/* ==========================================================================
 * Column reference lists
 * ========================================================================== */

opt_column_ref_commalist
    : /* empty */                       { $$ = nullptr; }
    | LPAREN column_ref_list RPAREN     { $$ = $<propNameListExp>2; }
    ;

column_ref_list
    : property_name_exp
        { auto pl = new PropertyNameListExp();
          auto p = std::unique_ptr<PropertyNameExp>($1);
          pl->AddPropertyNameExp(p);
          $<propNameListExp>$ = pl; }
    | column_ref_list COMMA property_name_exp
        { $<propNameListExp>$ = $<propNameListExp>1;
          auto p = std::unique_ptr<PropertyNameExp>($3);
          $<propNameListExp>$->AddPropertyNameExp(p); }
    ;

property_name_exp
    : NAME
        { PropertyPath pp; pp.Push(Utf8String($1));
          $$ = new PropertyNameExp(pp); free($1); }
    | NAME DOT NAME
        { PropertyPath pp; pp.Push(Utf8String($1)); pp.Push(Utf8String($3));
          $$ = new PropertyNameExp(pp); free($1); free($3); }
    ;

/* ==========================================================================
 * Assignment list (UPDATE SET)
 * ========================================================================== */

assignment_commalist
    : assignment_commalist COMMA assignment_item
        { $$ = $1; $$->AddAssignmentExp(std::unique_ptr<AssignmentExp>($<assignExp>3)); }
    | assignment_item
        { $$ = new AssignmentListExp();
          $$->AddAssignmentExp(std::unique_ptr<AssignmentExp>($<assignExp>1)); }
    ;

assignment_item
    : property_name_exp EQUAL value_exp
        { $<assignExp>$ = new AssignmentExp(
            std::unique_ptr<PropertyNameExp>($1),
            std::unique_ptr<ValueExp>($3)); }
    ;

/* ==========================================================================
 * Row value constructor comma list
 * ========================================================================== */

row_value_constructor_commalist
    : value_exp
        { $$ = new std::vector<std::unique_ptr<ValueExp>>();
          $$->push_back(std::unique_ptr<ValueExp>($1)); }
    | row_value_constructor_commalist COMMA value_exp
        { $$ = $1; $$->push_back(std::unique_ptr<ValueExp>($3)); }
    ;

/* ==========================================================================
 * Value expressions — precedence chain
 *
 * Actual precedence (lowest to highest):
 *   |  &  <<>>  +-  mul/div/mod  ||  unary
 * ========================================================================== */

value_exp
    : value_exp_or              { $$ = $1; }
    ;

value_exp_or
    : value_exp_and             { $$ = $1; }
    | value_exp_or BITWISE_OR value_exp_and
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::BitwiseOr, std::unique_ptr<ValueExp>($3)); }
    ;

value_exp_and
    : value_exp_shift           { $$ = $1; }
    | value_exp_and BITWISE_AND value_exp_shift
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::BitwiseAnd, std::unique_ptr<ValueExp>($3)); }
    ;

value_exp_shift
    : value_exp_addsub          { $$ = $1; }
    | value_exp_shift SHIFT_LEFT value_exp_addsub
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::ShiftLeft, std::unique_ptr<ValueExp>($3)); }
    | value_exp_shift SHIFT_RIGHT value_exp_addsub
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::ShiftRight, std::unique_ptr<ValueExp>($3)); }
    ;

value_exp_addsub
    : value_exp_muldiv          { $$ = $1; }
    | value_exp_addsub PLUS value_exp_muldiv
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::Plus, std::unique_ptr<ValueExp>($3)); }
    | value_exp_addsub MINUS value_exp_muldiv
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::Minus, std::unique_ptr<ValueExp>($3)); }
    ;

value_exp_muldiv
    : value_exp_concat          { $$ = $1; }
    | value_exp_muldiv STAR value_exp_concat
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::Multiply, std::unique_ptr<ValueExp>($3)); }
    | value_exp_muldiv SLASH value_exp_concat
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::Divide, std::unique_ptr<ValueExp>($3)); }
    | value_exp_muldiv PERCENT value_exp_concat
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::Modulo, std::unique_ptr<ValueExp>($3)); }
    ;

value_exp_concat
    : value_exp_unary           { $$ = $1; }
    | value_exp_concat CONCAT value_exp_unary
        { $$ = new BinaryValueExp(std::unique_ptr<ValueExp>($1),
            BinarySqlOperator::Concat, std::unique_ptr<ValueExp>($3)); }
    ;

value_exp_unary
    : value_exp_primary                     { $$ = $1; }
    | MINUS value_exp_primary
        { auto op = std::unique_ptr<ValueExp>($2);
          $$ = new UnaryValueExp(op, UnaryValueExp::Operator::Minus); }
    | PLUS value_exp_primary
        { auto op = std::unique_ptr<ValueExp>($2);
          $$ = new UnaryValueExp(op, UnaryValueExp::Operator::Plus); }
    | BITWISE_NOT value_exp_primary
        { auto op = std::unique_ptr<ValueExp>($2);
          $$ = new UnaryValueExp(op, UnaryValueExp::Operator::BitwiseNot); }
    ;

/* ==========================================================================
 * Primary value expressions
 * ========================================================================== */

value_exp_primary
    : literal                               { $$ = $1; }
    | PARAMETER
        { $$ = new ParameterExp(nullptr); }
    | NAMED_PARAM
        { $$ = new ParameterExp($1); free($1); }
    | DOLLAR
        {
            PropertyPath pp; pp.Push("$");
            $$ = new ExtractInstanceValueExp(pp);
        }
    | DOLLAR ARROW property_path
        {
            PropertyPath srcPath; srcPath.Push("$");
            PropertyPath targetPath; targetPath.Push($<strVal>3);
            $$ = new ExtractPropertyValueExp(srcPath, targetPath, false);
            free($<strVal>3);
        }
    | subquery
        { $$ = new SubqueryValueExp(std::unique_ptr<SubqueryExp>($1)); }
    | LPAREN value_exp RPAREN
        { $$ = $2; $$->SetHasParentheses(); }
    | cast_spec                             { $$ = $1; }
    | case_exp                              { $$ = $1; }
    | iif_exp                               { $$ = $1; }
    | KW_CURRENT_DATE
        { $$ = new FunctionCallExp(FunctionCallExp::CURRENT_DATE(),
            SqlSetQuantifier::NotSpecified, false, true); }
    | KW_CURRENT_TIME
        { $$ = new FunctionCallExp(FunctionCallExp::CURRENT_TIME(),
            SqlSetQuantifier::NotSpecified, false, true); }
    | KW_CURRENT_TIMESTAMP
        { $$ = new FunctionCallExp(FunctionCallExp::CURRENT_TIMESTAMP(),
            SqlSetQuantifier::NotSpecified, false, true); }
    | KW_DATE STRING_LITERAL
        { $$ = MakeLiteral(CTX, $2, ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_DateTime)).release();
          free($2); }
    | KW_TIME STRING_LITERAL
        { $$ = MakeLiteral(CTX, $2, ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_DateTime)).release();
          free($2); }
    | KW_TIMESTAMP STRING_LITERAL
        { $$ = MakeLiteral(CTX, $2, ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_DateTime)).release();
          free($2); }
    | column_ref_or_func                    { $$ = $1; }
    | STAR
        { $$ = MakeLiteral(CTX, Exp::ASTERISK_TOKEN,
            ECSqlTypeInfo(ECSqlTypeInfo::Kind::Varies)).release(); }
    ;

/* ==========================================================================
 * Literals
 * ========================================================================== */

literal
    : KW_NULL
        { $$ = MakeLiteral(CTX, "NULL", ECSqlTypeInfo(ECSqlTypeInfo::Kind::Null)).release(); }
    | KW_TRUE
        { $$ = MakeLiteral(CTX, "TRUE",
            ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_Boolean)).release(); }
    | KW_FALSE
        { $$ = MakeLiteral(CTX, "FALSE",
            ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_Boolean)).release(); }
    | INTEGER_LITERAL
        { $$ = MakeLiteral(CTX, $1,
            ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_Long)).release();
          free($1); }
    | APPROX_LITERAL
        { $$ = MakeLiteral(CTX, $1,
            ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_Double)).release();
          free($1); }
    | STRING_LITERAL
        { $$ = MakeLiteral(CTX, $1,
            ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_String)).release();
          free($1); }
    ;

/* ==========================================================================
 * CAST
 * ========================================================================== */

cast_spec
    : KW_CAST LPAREN value_exp KW_AS cast_type_name opt_array_marker RPAREN
        {
            ValueExp* operand = $3;
            Utf8String typeStr($<strVal>5); free($<strVal>5);
            bool isArray = $<boolVal>6;
            if (operand == nullptr)
                {
                YYABORT;
                }
            auto dotPos = typeStr.find('.');
            if (dotPos != Utf8String::npos)
                {
                Utf8String schema = typeStr.substr(0, dotPos);
                Utf8String typeName = typeStr.substr(dotPos + 1);
                $$ = new CastExp(std::unique_ptr<ValueExp>(operand), schema, typeName, isArray);
                }
            else
                {
                $$ = new CastExp(std::unique_ptr<ValueExp>(operand), typeStr.c_str(), isArray);
                }
        }
    ;

cast_type_name
    : KW_BINARY   { $<strVal>$ = strdup("BINARY"); }
    | KW_BLOB     { $<strVal>$ = strdup("BLOB"); }
    | KW_BOOLEAN  { $<strVal>$ = strdup("BOOLEAN"); }
    | KW_DATE     { $<strVal>$ = strdup("DATE"); }
    | KW_DOUBLE   { $<strVal>$ = strdup("DOUBLE"); }
    | KW_FLOAT    { $<strVal>$ = strdup("FLOAT"); }
    | KW_INT      { $<strVal>$ = strdup("INT"); }
    | KW_INT64    { $<strVal>$ = strdup("INT64"); }
    | KW_LONG     { $<strVal>$ = strdup("LONG"); }
    | KW_REAL     { $<strVal>$ = strdup("REAL"); }
    | KW_STRING_KW { $<strVal>$ = strdup("STRING"); }
    | KW_TIME     { $<strVal>$ = strdup("TIME"); }
    | KW_TIMESTAMP { $<strVal>$ = strdup("TIMESTAMP"); }
    | KW_VARCHAR  { $<strVal>$ = strdup("VARCHAR"); }
    | NAME        { $<strVal>$ = $1; }
    | NAME DOT NAME
        { /* schema.TypeName */
          char buf[256]; snprintf(buf, sizeof(buf), "%s.%s", $1, $3);
          $<strVal>$ = strdup(buf); free($1); free($3); }
    ;

opt_array_marker
    : /* empty */       { $<boolVal>$ = false; }
    | LBRACKET RBRACKET { $<boolVal>$ = true; }
    ;

/* ==========================================================================
 * CASE
 * ========================================================================== */

case_exp
    : KW_CASE when_clause_list opt_else_clause KW_END
        {
            $$ = new SearchCaseValueExp(*$<whenClauseVec>2,
                std::unique_ptr<ValueExp>($<valueExp>3));
            delete $<whenClauseVec>2;
        }
    ;

when_clause_list
    : when_clause
        { $<whenClauseVec>$ = new std::vector<std::unique_ptr<SearchedWhenClauseExp>>();
          $<whenClauseVec>$->push_back(std::unique_ptr<SearchedWhenClauseExp>(static_cast<SearchedWhenClauseExp*>($<valueExp>1))); }
    | when_clause_list when_clause
        { $<whenClauseVec>$ = $<whenClauseVec>1;
          $<whenClauseVec>$->push_back(std::unique_ptr<SearchedWhenClauseExp>(static_cast<SearchedWhenClauseExp*>($<valueExp>2))); }
    ;

when_clause
    : KW_WHEN search_condition KW_THEN value_exp
        {
            auto cond = std::unique_ptr<BooleanExp>($2);
            auto then_val = std::unique_ptr<ValueExp>($4);
            $<valueExp>$ = (ValueExp*)(new SearchedWhenClauseExp(cond, then_val));
        }
    ;

opt_else_clause
    : /* empty */       { $<valueExp>$ = nullptr; }
    | KW_ELSE value_exp { $<valueExp>$ = $2; }
    ;

/* ==========================================================================
 * IIF
 * ========================================================================== */

iif_exp
    : KW_IIF LPAREN search_condition COMMA value_exp COMMA value_exp RPAREN
        {
            auto cond = std::unique_ptr<BooleanExp>($3);
            auto thenV = std::unique_ptr<ValueExp>($5);
            auto elseV = std::unique_ptr<ValueExp>($7);
            $$ = new IIFExp(cond, thenV, elseV);
        }
    ;

/* ==========================================================================
 * Column reference / function call
 * ========================================================================== */

column_ref_or_func
    : NAME
        { PropertyPath pp; pp.Push(Utf8String($1));
          $$ = new PropertyNameExp(pp); free($1); }
    | NAME DOT NAME
        { PropertyPath pp; pp.Push(Utf8String($1)); pp.Push(Utf8String($3));
          $$ = new PropertyNameExp(pp); free($1); free($3); }
    | NAME DOT NAME DOT NAME
        {
            /* 3-part property path — or schema.enum.enumerator (RESOLVE at finalize) */
            PropertyPath pp;
            pp.Push(Utf8String($1)); pp.Push(Utf8String($3)); pp.Push(Utf8String($5));
            $$ = new PropertyNameExp(pp);
            free($1); free($3); free($5);
        }
    | function_call                         { $$ = $1; }
    ;

function_call
    : NAME LPAREN RPAREN
        { $$ = new FunctionCallExp(Utf8String($1)); free($1); }
    | NAME LPAREN opt_set_quantifier func_arg_list RPAREN
        {
            auto fc = new FunctionCallExp(Utf8String($1), $3, false);
            for (auto& a : *$<valueExpVec>4)
                fc->AddArgument(std::move(a));
            $$ = fc;
            free($1); delete $<valueExpVec>4;
        }
    | NAME LPAREN STAR RPAREN
        {
            /* COUNT(*) */
            Utf8String fname($1);
            fname.ToUpper();
            auto fc = new FunctionCallExp(fname, SqlSetQuantifier::NotSpecified, true);
            auto starExp = MakeLiteral(CTX, Exp::ASTERISK_TOKEN,
                ECSqlTypeInfo(ECSqlTypeInfo::Kind::Varies));
            fc->AddArgument(std::move(starExp));
            $$ = fc; free($1);
        }
    ;

func_arg_list
    : value_exp
        { $<valueExpVec>$ = new std::vector<std::unique_ptr<ValueExp>>();
          $<valueExpVec>$->push_back(std::unique_ptr<ValueExp>($1)); }
    | func_arg_list COMMA value_exp
        { $<valueExpVec>$ = $<valueExpVec>1;
          $<valueExpVec>$->push_back(std::unique_ptr<ValueExp>($3)); }
    ;

/* Property path — used in -> extraction */
property_path
    : NAME
        { $<strVal>$ = $1; /* simplified — full impl uses PropertyPath object */ }
    | property_path DOT NAME
        { $<strVal>$ = $<strVal>1; /* simplified */ free($3); }
    ;

/* ==========================================================================
 * Value expression comma list
 * ========================================================================== */

value_exp_commalist
    : value_exp
        { $$ = new ValueExpListExp();
          auto v = std::unique_ptr<ValueExp>($1);
          $$->AddValueExp(v); }
    | value_exp_commalist COMMA value_exp
        { $$ = $1;
          auto v = std::unique_ptr<ValueExp>($3);
          $$->AddValueExp(v); }
    ;

/* ==========================================================================
 * Search condition (boolean)
 * ========================================================================== */

search_condition
    : search_condition_or       { $$ = $1; }
    ;

search_condition_or
    : search_condition_and      { $$ = $1; }
    | search_condition_or KW_OR search_condition_and
        { $$ = new BinaryBooleanExp(
            std::unique_ptr<ComputedExp>($1),
            BooleanSqlOperator::Or,
            std::unique_ptr<ComputedExp>($3)); }
    ;

search_condition_and
    : search_condition_not      { $$ = $1; }
    | search_condition_and KW_AND search_condition_not
        { $$ = new BinaryBooleanExp(
            std::unique_ptr<ComputedExp>($1),
            BooleanSqlOperator::And,
            std::unique_ptr<ComputedExp>($3)); }
    ;

search_condition_not
    : predicate                 { $$ = $1; }
    | KW_NOT predicate
        { $$ = new BooleanFactorExp(std::unique_ptr<BooleanExp>($2), true); }
    ;

/* ==========================================================================
 * Predicate
 * ========================================================================== */

predicate
    : LPAREN search_condition RPAREN
        { $$ = $2; $$->SetHasParentheses(); }
    | KW_EXISTS subquery
        { $$ = new SubqueryTestExp(SubqueryTestOperator::Exists,
            std::unique_ptr<SubqueryExp>($2)); }
    | KW_UNIQUE subquery
        { $$ = new SubqueryTestExp(SubqueryTestOperator::Unique,
            std::unique_ptr<SubqueryExp>($2)); }
    | value_exp KW_IS opt_not KW_NULL
        {
            auto rhs = MakeLiteral(CTX, "NULL", ECSqlTypeInfo(ECSqlTypeInfo::Kind::Null));
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1),
                $3 ? BooleanSqlOperator::IsNot : BooleanSqlOperator::Is,
                std::unique_ptr<ComputedExp>(rhs.release()));
        }
    | value_exp KW_IS opt_not KW_TRUE
        {
            auto rhs = MakeLiteral(CTX, "TRUE",
                ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_Boolean));
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1),
                $3 ? BooleanSqlOperator::IsNot : BooleanSqlOperator::Is,
                std::unique_ptr<ComputedExp>(rhs.release()));
        }
    | value_exp KW_IS opt_not KW_FALSE
        {
            auto rhs = MakeLiteral(CTX, "FALSE",
                ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_Boolean));
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1),
                $3 ? BooleanSqlOperator::IsNot : BooleanSqlOperator::Is,
                std::unique_ptr<ComputedExp>(rhs.release()));
        }
    | value_exp KW_IS opt_not LPAREN type_list RPAREN
        {
            auto typeList = std::unique_ptr<ValueExp>(new TypeListExp(*$5));
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1),
                $3 ? BooleanSqlOperator::IsNot : BooleanSqlOperator::Is,
                std::unique_ptr<ComputedExp>(typeList.release()));
            delete $5;
        }
    | value_exp opt_not KW_BETWEEN value_exp KW_AND value_exp
        {
            auto range = std::make_unique<BetweenRangeValueExp>(
                std::unique_ptr<ValueExp>($4), std::unique_ptr<ValueExp>($6));
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1),
                $2 ? BooleanSqlOperator::NotBetween : BooleanSqlOperator::Between,
                std::unique_ptr<ComputedExp>(range.release()));
        }
    | value_exp opt_not KW_LIKE value_exp opt_escape
        {
            auto rhsExp = std::make_unique<LikeRhsValueExp>(
                std::unique_ptr<ValueExp>($4),
                $5 ? std::unique_ptr<ValueExp>($5) : nullptr);
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1),
                $2 ? BooleanSqlOperator::NotLike : BooleanSqlOperator::Like,
                std::unique_ptr<ComputedExp>(rhsExp.release()));
        }
    | value_exp opt_not KW_IN subquery
        {
            auto subVal = std::make_unique<SubqueryValueExp>(
                std::unique_ptr<SubqueryExp>($4));
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1),
                $2 ? BooleanSqlOperator::NotIn : BooleanSqlOperator::In,
                std::unique_ptr<ComputedExp>(subVal.release()));
        }
    | value_exp opt_not KW_IN LPAREN value_exp_commalist RPAREN
        {
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1),
                $2 ? BooleanSqlOperator::NotIn : BooleanSqlOperator::In,
                std::unique_ptr<ComputedExp>($5));
        }
    | value_exp opt_not KW_MATCH function_call
        {
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1),
                $2 ? BooleanSqlOperator::NotMatch : BooleanSqlOperator::Match,
                std::unique_ptr<ComputedExp>($4));
        }
    | value_exp comparison_op quantifier subquery
        {
            $$ = new AllOrAnyExp(
                std::unique_ptr<ValueExp>($1), $2, $3,
                std::unique_ptr<SubqueryExp>($4));
        }
    | value_exp comparison_op value_exp
        {
            $$ = new BinaryBooleanExp(
                std::unique_ptr<ComputedExp>($1), $2,
                std::unique_ptr<ComputedExp>($3));
        }
    | value_exp
        { $$ = new UnaryPredicateExp(std::unique_ptr<ValueExp>($1)); }
    ;

opt_not
    : /* empty */       { $$ = false; }
    | KW_NOT            { $$ = true; }
    ;

opt_escape
    : /* empty */           { $$ = nullptr; }
    | KW_ESCAPE STRING_LITERAL
        { $$ = MakeLiteral(CTX, $2,
            ECSqlTypeInfo::CreatePrimitive(ECN::PRIMITIVETYPE_String)).release();
          free($2); }
    ;

comparison_op
    : EQUAL         { $$ = BooleanSqlOperator::EqualTo; }
    | LESS          { $$ = BooleanSqlOperator::LessThan; }
    | GREAT         { $$ = BooleanSqlOperator::GreaterThan; }
    | LESS_EQ       { $$ = BooleanSqlOperator::LessThanOrEqualTo; }
    | GREAT_EQ      { $$ = BooleanSqlOperator::GreaterThanOrEqualTo; }
    | NOT_EQUAL     { $$ = BooleanSqlOperator::NotEqualTo; }
    ;

quantifier
    : KW_ALL        { $$ = SqlCompareListType::All; }
    | KW_ANY        { $$ = SqlCompareListType::Any; }
    | KW_SOME       { $$ = SqlCompareListType::Some; }
    ;

/* ==========================================================================
 * Type predicate list
 * ========================================================================== */

type_list
    : type_list_entry
        { $$ = new std::vector<std::unique_ptr<ClassNameExp>>();
          $$->push_back(std::unique_ptr<ClassNameExp>($1)); }
    | type_list COMMA type_list_entry
        { $$ = $1; $$->push_back(std::unique_ptr<ClassNameExp>($3)); }
    ;

type_list_entry
    : opt_polymorphic_constraint table_node
        { $$ = $2; delete $1; }
    ;

/* ==========================================================================
 * Window specification
 * ========================================================================== */

window_specification
    : opt_partition_clause opt_order_by_clause opt_frame_clause
        {
            $$ = new WindowSpecification(
                Utf8String(""),
                $1 ? std::unique_ptr<WindowPartitionColumnReferenceListExp>($1) : nullptr,
                $2 ? std::unique_ptr<OrderByExp>($2) : nullptr,
                $3 ? std::unique_ptr<WindowFrameClauseExp>($3) : nullptr);
        }
    | NAME opt_partition_clause opt_order_by_clause opt_frame_clause
        {
            $$ = new WindowSpecification(
                Utf8String($1),
                $2 ? std::unique_ptr<WindowPartitionColumnReferenceListExp>($2) : nullptr,
                $3 ? std::unique_ptr<OrderByExp>($3) : nullptr,
                $4 ? std::unique_ptr<WindowFrameClauseExp>($4) : nullptr);
            free($1);
        }
    ;

opt_partition_clause
    : /* empty */               { $$ = nullptr; }
    | KW_PARTITION KW_BY partition_column_list
        { $$ = new WindowPartitionColumnReferenceListExp(*$3); delete $3; }
    ;

partition_column_list
    : column_ref_or_func opt_collate_clause
        { $$ = new std::vector<std::unique_ptr<WindowPartitionColumnReferenceExp>>();
          $$->push_back(std::make_unique<WindowPartitionColumnReferenceExp>(
            std::unique_ptr<ValueExp>($1), $2)); }
    | partition_column_list COMMA column_ref_or_func opt_collate_clause
        { $$ = $1;
          $$->push_back(std::make_unique<WindowPartitionColumnReferenceExp>(
            std::unique_ptr<ValueExp>($3), $4)); }
    ;

opt_collate_clause
    : /* empty */       { $$ = WindowPartitionColumnReferenceExp::CollateClauseFunction::NotSpecified; }
    | KW_COLLATE KW_BINARY  { $$ = WindowPartitionColumnReferenceExp::CollateClauseFunction::Binary; }
    | KW_COLLATE KW_NOCASE  { $$ = WindowPartitionColumnReferenceExp::CollateClauseFunction::NoCase; }
    | KW_COLLATE KW_RTRIM   { $$ = WindowPartitionColumnReferenceExp::CollateClauseFunction::Rtrim; }
    ;

/* ==========================================================================
 * Window frame clause
 * ========================================================================== */

opt_frame_clause
    : /* empty */               { $$ = nullptr; }
    | frame_unit frame_start opt_frame_exclusion
        { $$ = new WindowFrameClauseExp($1, $3,
            std::unique_ptr<WindowFrameStartExp>($2)); }
    | frame_unit frame_between opt_frame_exclusion
        { $$ = new WindowFrameClauseExp($1, $3,
            std::unique_ptr<WindowFrameBetweenExp>($2)); }
    ;

frame_unit
    : KW_ROWS           { $$ = WindowFrameClauseExp::WindowFrameUnit::Rows; }
    | KW_RANGE          { $$ = WindowFrameClauseExp::WindowFrameUnit::Range; }
    | KW_GROUPS         { $$ = WindowFrameClauseExp::WindowFrameUnit::Groups; }
    ;

frame_start
    : KW_UNBOUNDED KW_PRECEDING
        { $$ = new WindowFrameStartExp(WindowFrameStartExp::WindowFrameStartType::UnboundedPreceding); }
    | KW_CURRENT KW_ROW
        { $$ = new WindowFrameStartExp(WindowFrameStartExp::WindowFrameStartType::CurrentRow); }
    | value_exp KW_PRECEDING
        { $$ = new WindowFrameStartExp(WindowFrameStartExp::WindowFrameStartType::ValuePreceding,
            std::unique_ptr<ValueExp>($1)); }
    ;

frame_between
    : KW_BETWEEN first_frame_bound KW_AND second_frame_bound
        { $$ = new WindowFrameBetweenExp(
            std::unique_ptr<FirstWindowFrameBoundExp>($2),
            std::unique_ptr<SecondWindowFrameBoundExp>($4)); }
    ;

first_frame_bound
    : KW_UNBOUNDED KW_PRECEDING
        { $$ = new FirstWindowFrameBoundExp(
            FirstWindowFrameBoundExp::WindowFrameBoundType::UnboundedPreceding); }
    | KW_CURRENT KW_ROW
        { $$ = new FirstWindowFrameBoundExp(
            FirstWindowFrameBoundExp::WindowFrameBoundType::CurrentRow); }
    | value_exp KW_PRECEDING
        { $$ = new FirstWindowFrameBoundExp(std::unique_ptr<ValueExp>($1),
            FirstWindowFrameBoundExp::WindowFrameBoundType::ValuePreceding); }
    | value_exp KW_FOLLOWING
        { $$ = new FirstWindowFrameBoundExp(std::unique_ptr<ValueExp>($1),
            FirstWindowFrameBoundExp::WindowFrameBoundType::ValueFollowing); }
    ;

second_frame_bound
    : KW_UNBOUNDED KW_FOLLOWING
        { $$ = new SecondWindowFrameBoundExp(
            SecondWindowFrameBoundExp::WindowFrameBoundType::UnboundedFollowing); }
    | KW_CURRENT KW_ROW
        { $$ = new SecondWindowFrameBoundExp(
            SecondWindowFrameBoundExp::WindowFrameBoundType::CurrentRow); }
    | value_exp KW_PRECEDING
        { $$ = new SecondWindowFrameBoundExp(std::unique_ptr<ValueExp>($1),
            SecondWindowFrameBoundExp::WindowFrameBoundType::ValuePreceding); }
    | value_exp KW_FOLLOWING
        { $$ = new SecondWindowFrameBoundExp(std::unique_ptr<ValueExp>($1),
            SecondWindowFrameBoundExp::WindowFrameBoundType::ValueFollowing); }
    ;

opt_frame_exclusion
    : /* empty */
        { $$ = WindowFrameClauseExp::WindowFrameExclusionType::NotSpecified; }
    | KW_EXCLUDE KW_GROUP
        { $$ = WindowFrameClauseExp::WindowFrameExclusionType::ExcludeGroup; }
    | KW_EXCLUDE KW_TIES
        { $$ = WindowFrameClauseExp::WindowFrameExclusionType::ExcludeTies; }
    | KW_EXCLUDE KW_CURRENT KW_ROW
        { $$ = WindowFrameClauseExp::WindowFrameExclusionType::ExcludeCurrentRow; }
    | KW_EXCLUDE KW_NO KW_OTHERS
        { $$ = WindowFrameClauseExp::WindowFrameExclusionType::ExcludeNoOthers; }
    ;

/* ==========================================================================
 * Filter clause (for window functions)
 * ========================================================================== */

opt_filter_clause
    : /* empty */               { $$ = nullptr; }
    | KW_FILTER LPAREN where_clause RPAREN
        { $$ = new FilterClauseExp(std::unique_ptr<WhereExp>($3)); }
    ;

/* ==========================================================================
 * Identifier
 * ========================================================================== */

identifier
    : NAME              { $$ = $1; }
    ;

%%

/* ==========================================================================
 * Error handler
 * ========================================================================== */

void yyerror(ECSqlParseContext* ctx, void* scanner, const char* msg)
    {
    ctx->Issues().ReportV(IssueSeverity::Error,
        IssueCategory::BusinessProperties, ECN::IssueType::ECSQL,
        ECDbIssueId::ECDb_0471,
        "Failed to parse ECSQL: %s", msg);
    }

/* ==========================================================================
 * Notes:
 *
 * 1. CLASS RESOLUTION: ClassNameExp constructors here pass nullptr for the
 *    Info pointer.  The FinalizeParsing pass (already part of the existing
 *    pipeline) calls TryResolveClass to fill in the ClassMap.
 *
 * 2. JOIN LHS: BISON mid-rule values ($-1) would carry the LHS table_ref
 *    into join_clause.  The pattern shown uses nullptr placeholders; a
 *    production integration would use inherited attributes or restructure
 *    the grammar to pass the LHS explicitly.
 *
 * 3. WINDOW OVER: The RD parser checks for OVER/FILTER after every function
 *    call.  In BISON, this would be expressed as an optional trailer on
 *    function_call productions (omitted for clarity; the ANTLR grammar
 *    shows the full pattern).
 *
 * 4. VIEW EXPANSION / ENUM RESOLUTION: These are semantic operations done
 *    during FinalizeParsing, not during grammar reduction.
 *
 * 5. MEMORY: Production code should use %destructor to free heap values
 *    on parse error.  Omitted here for readability.
 * ========================================================================== */
