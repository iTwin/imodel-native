# Shared vcpkg helpers for libsrc .mke files.
#---------------------------------------------------------------------------------------------

#--------------------------------------------------------------------------------------
#   Determine vcpkg triplet from TARGET_PROCESSOR_ARCHITECTURE
#--------------------------------------------------------------------------------------
%if $(TARGET_PROCESSOR_ARCHITECTURE) == "MacOSARM64"
    vcpkgTriplet = arm64-osx
%elif $(TARGET_PROCESSOR_ARCHITECTURE) == "MacOSX64"
    vcpkgTriplet = x64-osx
%elif $(TARGET_PROCESSOR_ARCHITECTURE) == "iOSARM64"
    vcpkgTriplet = arm64-ios
%elif $(TARGET_PROCESSOR_ARCHITECTURE) == "LinuxX64"
    vcpkgTriplet = x64-linux
%elif $(TARGET_PROCESSOR_ARCHITECTURE) == "x64"
    %if defined (IS_VERACODE_BUILD)
        vcpkgTriplet = x64-windows-static-veracode
    %else
        vcpkgTriplet = x64-windows-static
    %endif
%else
    %error Unsupported TARGET_PROCESSOR_ARCHITECTURE for vcpkg: $(TARGET_PROCESSOR_ARCHITECTURE)
%endif
