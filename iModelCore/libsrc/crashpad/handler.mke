#---------------------------------------------------------------------------------------------
# handler.mke - Deliver CrashpadHandler via vcpkg, with optional legacy fallback.
#---------------------------------------------------------------------------------------------

%include mdl.mki
%include $(SrcRoot)bsicommon/sharedmki/stdversion.mki

appName             = CrashpadHandler
crashpadDir         = $(_MakeFilePath)
libsrcDir           = $(crashpadDir)../

o                   = $(OutputRootDir)build/$(appName)/

#--------------------------------------------------------------------------------------
#   Determine vcpkg triplet from TARGET_PROCESSOR_ARCHITECTURE
#--------------------------------------------------------------------------------------
%include $(libsrcDir)vcpkg.mki

%if defined (winNT)
	%if !defined (MSJ_SKIP_SIGNRSCS)
		%include $(SrcRoot)bsicommon/PublicSDK/signrscsdefs.mki
	%endif
%endif

vcpkgInstallRoot    = $(OutputRootDir)vcpkg_installed/crashpad/
vcpkgTripletDir     = $(vcpkgInstallRoot)$(vcpkgTriplet)/
%if $(TARGET_PLATFORM)=="Windows"
	vcpkgHandlerExe     = $(vcpkgTripletDir)tools/crashpad_handler$(exeext)
%elif defined (DEBUG)
	vcpkgHandlerExe     = $(vcpkgTripletDir)debug/tools/crashpad_handler$(exeext)
%else
	vcpkgHandlerExe     = $(vcpkgTripletDir)tools/crashpad_handler$(exeext)
%endif
handlerOut          = $(o)$(appName)$(exeext)

#--------------------------------------------------------------------------------------
#   Run vcpkg to build crashpad artifacts.
#--------------------------------------------------------------------------------------
always:
	!~@mkdir $(o)
%if defined (winNT)
	$(libsrcDir)vcpkg_run_install.bat $(crashpadDir) $(vcpkgInstallRoot) $(vcpkgTriplet)
%else
	$(libsrcDir)vcpkg_run_install.sh $(crashpadDir) $(vcpkgInstallRoot) $(vcpkgTriplet)
%endif

#--------------------------------------------------------------------------------------
#   Deliver handler executable with expected product name.
#--------------------------------------------------------------------------------------
"$(handlerOut)" : $(vcpkgHandlerExe)
	~linkfile "$@=$<"
%if !defined (winNT)
	chmod +x "$(vcpkgHandlerExe)"
	chmod +x "$@"
%endif

%if defined (winNT)
	# Stamp the delivered executable with this build's standard version metadata.
always:
	$(InjectVersionCmd) "$(handlerOut)" $(STD_VERSION_OPTS) -k"FileDescription=$(appName) for Windows" -k"InternalName=$(appName)$(exeext)" -k"OriginalFilename=$(appName)$(exeext)" -k"ProductName=$(appName)"

%if !defined (MSJ_SKIP_SIGNRSCS)
%if defined (signcodecmd)
always:
	$(signcodecmd) "$(handlerOut)"
%else
	%warn signcodecmd is not defined; skipping signing for $(handlerOut)
%endif
%endif
%endif

"$(BuildContext)Delivery/$(appName)$(exeext)" : "$(handlerOut)"
	$(LinkFirstDepToFirstTarget)
%if !defined (winNT)
	chmod +x "$@"
%endif
