#---------------------------------------------------------------------------------------------
# handler.mke - Deliver CrashpadHandler via vcpkg, with optional legacy fallback.
#---------------------------------------------------------------------------------------------

# Toggle for rollout/testing:
#   - default: deliver handler built by vcpkg (this file)
#   - legacy:  pass -dUSE_LEGACY_CRASHPAD_HANDLER_MKE=1 to build via handler_legacy.mke
%if defined (USE_LEGACY_CRASHPAD_HANDLER_MKE)
	%include $(_MakeFilePath)handler_legacy.mke
	%return
%endif

%include mdl.mki

%if $(TARGET_PLATFORM)=="Windows"
	%error Need to comment out this line to make it compile
%endif

appName             = CrashpadHandler
crashpadDir         = $(_MakeFilePath)
libsrcDir           = $(crashpadDir)../

o                   = $(OutputRootDir)build/$(appName)/

#--------------------------------------------------------------------------------------
#   Determine vcpkg triplet from TARGET_PROCESSOR_ARCHITECTURE
#--------------------------------------------------------------------------------------
%include $(libsrcDir)vcpkg.mki

vcpkgInstallRoot    = $(OutputRootDir)vcpkg_installed/crashpad/
vcpkgTripletDir     = $(vcpkgInstallRoot)$(vcpkgTriplet)/
%if defined (DEBUG)
	vcpkgHandlerExe     = $(vcpkgTripletDir)tools/crashpad/debug/crashpad_handler$(exeext)
%else
	vcpkgHandlerExe     = $(vcpkgTripletDir)tools/crashpad/crashpad_handler$(exeext)
%endif
handlerOut          = $(o)$(appName)$(exeext)

#--------------------------------------------------------------------------------------
#   Run vcpkg to build crashpad artifacts.
#--------------------------------------------------------------------------------------
always:
	!~@mkdir $(o)
%if $(TARGET_PLATFORM) == "Windows"
	$(libsrcDir)vcpkg_run_install.bat $(crashpadDir) $(vcpkgInstallRoot) $(vcpkgTriplet)
%else
	$(libsrcDir)vcpkg_run_install.sh $(crashpadDir) $(vcpkgInstallRoot) $(vcpkgTriplet)
%endif

#--------------------------------------------------------------------------------------
#   Deliver handler executable with expected product name.
#--------------------------------------------------------------------------------------
always:
	~linkfile "$(handlerOut)=$(vcpkgHandlerExe)"
	~linkfile "$(BuildContext)Delivery/$(appName)$(exeext)=$(handlerOut)"
