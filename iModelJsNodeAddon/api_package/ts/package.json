{
  "name": "imodeljs-native-typescript-api",
  "version": "0.0.1",
  "description": "TypeScript API of imodeljs-native",
  "private": true,
  "engines": {
    "node": "^20.0.0 || ^22.0.0"
  },
  "scripts": {
    "build": "tsc 1>&2",
    "lint": "eslint -f visualstudio \"./src/**/*.ts\" 1>&2",
    "lint-fix": "eslint --fix -f visualstudio \"./src/**/*.ts\" 1>&2",
    "buildAndLint": "npm run -s build && npm run -s lint",
    "clean": "rimraf lib",
    "copy:test-assets": "cpx \"./assets/test/**/*\" ./lib/test/assets",
    "pretest": "npm run copy:test-assets",
    "test": "node ./lib/test/index.js"
  },
  "devDependencies": {
    "@itwin/build-tools": "^5.0.0",
    "@itwin/core-bentley": "^5.0.0",
    "@itwin/core-common": "^5.0.0",
    "@itwin/core-geometry": "^5.0.0",
    "@itwin/eslint-plugin": "^6.0.0",
    "@types/chai": "^4.3.6",
    "@types/chai-as-promised": "^7.1.6",
    "@types/fs-extra": "^4.0.13",
    "@types/mocha": "^5.2.7",
    "@types/node": "~20.17.0",
    "@types/sinon": "^9.0.11",
    "chai": "^4.3.10",
    "chai-as-promised": "^7.1.1",
    "cpx2": "^8.0.0",
    "eslint": "^9.39.3",
    "fs-extra": "^8.1.0",
    "mocha": "^11.7.5",
    "rimraf": "^2.7.1",
    "sinon": "^9.2.4",
    "typescript": "~5.6.2"
  },
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.3",
    "lunr": {
      "mocha": "10.1.0"
    }

  }
}
